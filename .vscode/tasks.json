{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Generar Examen (PowerShell)",
			"type": "shell",
			"command": "/usr/local/bin/python3",
			"args": [
				"src/generar_examen.py"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Servidor Local (Python)",
			"type": "shell",
			"command": "/usr/local/bin/python3",
			"args": [
				"src/server.py"
			],
			"isBackground": true,
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Servidor Local (PostgreSQL)",
			"type": "shell",
			"command": "/bin/zsh",
			"args": [
				"-lc",
				"source .venv-pg/bin/activate && EXAM_DB_URL='postgresql://pablorosasbogeat@localhost:5432/examenes_local' /usr/local/bin/python3 src/server.py"
			],
			"isBackground": true,
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Detener Servidor Local (8001)",
			"type": "shell",
			"command": "/bin/zsh",
			"args": [
				"-lc",
				"lsof -ti tcp:8001 | xargs kill -9 2>/dev/null || true"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Cliente BD Web (pgweb)",
			"type": "shell",
			"command": "/bin/zsh",
			"args": [
				"-lc",
				"pgweb --host localhost --port 5432 --db examenes_local --user pablorosasbogeat --bind 127.0.0.1 --listen 8081 --skip-open"
			],
			"isBackground": true,
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Detener Cliente BD Web (8081)",
			"type": "shell",
			"command": "/bin/zsh",
			"args": [
				"-lc",
				"lsof -ti tcp:8081 | xargs kill -9 2>/dev/null || true"
			],
			"group": "build",
			"problemMatcher": []
		}
	]
}